{
  "name": "@obinexusmk2/nexus-search",
  "version": "0.4.0",
  "description": "A high-performance search indexing and query system using a self-balancing AVL-Trie with BFS/DFS algorithms for fast full-text search, fuzzy matching, real-time updates, and cross-platform file system support.",
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "browser": "./dist/index.umd.js",
      "types": "./dist/index.d.ts"
    }
  },
  "bin": {
    "nsc": "dist/cli/index.js",
    "nscli": "dist/cli/index.js"
  },
  "files": [
    "dist/",
    "src/",
    "README.md",
    "fixtures/",
    "docs/",
    "LICENSE",
    "examples/",
    "scripts/"
  ],
  "scripts": {
    "clean": "rm -rf dist",
    "prebuild": "npm run clean",
    "build:core": "rollup -c ./rollup.config.js",
    "build:cli": "rollup -c ./config/rollup.config.core.js",
    "build": "npm run build:core && npm run build:cli",
    "build:watch": "rollup -c -w",
    "postbuild": "node scripts/verify-build.js",
    "demo": "node fixtures/server.js",
    "dev": "rollup -c -w",
    "prepublishOnly": "npm run build",
    "prepare": "npm run build",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/ --ext .ts",
    "format": "prettier --write 'src/**/*.ts'",
    "migrate": "bash scripts/migrate_nofs.sh",
    "migrate:dry": "DRYRUN=1 bash scripts/migrate_nofs.sh"
  },
  "funding": {
    "type": "individual",
    "url": "https://www.buymeacoffee.com/obinexuscomputing"
  },
  "dependencies": {
    "idb": ">=7.0.0",
    "punycode": "^2.3.1",
    "tslib": "^2.8.1"
  },
  "peerDependencies": {
    "idb": ">=7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.16.0",
    "@rollup/plugin-alias": "^5.1.1",
    "@rollup/plugin-commonjs": "^28.0.9",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "@testing-library/jest-dom": "^6.4.2",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.10.2",
    "@types/punycode": "^2.1.4",
    "@typescript-eslint/eslint-plugin": "^5.57.1",
    "@typescript-eslint/parser": "^5.57.1",
    "eslint": "^8.57.1",
    "globals": "^15.12.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "prettier": "^3.2.5",
    "rimraf": "^6.1.3",
    "rollup": "^4.59.0",
    "rollup-plugin-dts": "^6.3.0",
    "rollup-plugin-typescript2": "^0.36.0",
    "ts-jest": "^29.2.5",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.16.0"
  },
  "directories": {
    "doc": "docs",
    "fixtures": "fixtures",
    "dist": "dist",
    "src": "src",
    "test": "__tests__"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "keywords": [
    "@obinexuscomputing/nexus-search",
    "nexus-search",
    "avl-trie",
    "bfs",
    "dfs",
    "trie",
    "search",
    "indexing",
    "fuzzy-search",
    "fuzzy matching",
    "real-time updates",
    "typescript",
    "indexeddb",
    "pagerank",
    "seo",
    "high-performance",
    "nested fields",
    "caching",
    "file-system",
    "cross-platform"
  ],
  "author": "Nnamdi Michael Okpala",
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "https://gitlab.com/obinexuscomputing.pkg/nexus-search"
  }
}
